# MarketScraper environment configuration
# Copy this file to `.env` (or set the variables in your hosting provider) and fill values.

# === Database ===
# Leave empty to use the local SQLite file at backend/reiwa.db (good for dev).
# Set to a Neon / Supabase / any Postgres URL for production / cloud cron.
# Example: postgresql://user:pass@ep-xyz.aws.neon.tech/marketscraper?sslmode=require
DATABASE_URL=

# === Playwright ===
# Pinned Chromium location used inside the GitHub Actions runner. Locally
# Playwright auto-detects via `playwright install chromium` so leave empty.
# CHROMIUM_PATH=

# === Future: auth, alerts, etc. ===
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
